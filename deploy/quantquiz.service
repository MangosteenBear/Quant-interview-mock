[Unit]
Description=QuantQuiz FastAPI Backend
After=network.target postgresql.service

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/Quant-interview-mock/backend
EnvironmentFile=/home/ubuntu/Quant-interview-mock/backend/.env
ExecStart=/home/ubuntu/Quant-interview-mock/backend/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
